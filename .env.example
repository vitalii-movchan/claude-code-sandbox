# Образец окружения для landing — скопируй в .env и заполни.
# .env в git не попадает (см. .gitignore), .env.example — попадает.
# Подгрузить в шелл: set -a; . .env; set +a

# --- landing-page-media: SOURCE=stock (нужен ОДИН из двух) ---
# Unsplash: https://unsplash.com/oauth/applications → Access Key
UNSPLASH_ACCESS_KEY=
# Pexels: https://www.pexels.com/api/ → API Key
PEXELS_API_KEY=

# --- landing-page-media: STORAGE=vercel-blob ---
# Vercel → Storage → Blob → нужный store → ".env.local" → BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=
